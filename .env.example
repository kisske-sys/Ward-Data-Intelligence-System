# ── Firebase (ดูได้จาก Firebase Console → Project Settings → Your apps) ──────
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Auth (ตั้งใน Vercel Environment Variables) ────────────────────────────────
EDITOR_PASSWORD=admin1234
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# ── LINE Notify (ตั้งใน Vercel Environment Variables) ────────────────────────
# ถ้าต้องการแจ้งเตือน LINE ให้ใส่ token ที่นี่
# LINE_NOTIFY_TOKEN=your-line-notify-token
